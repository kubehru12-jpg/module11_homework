Задание 1
function countEvenOddAndZero(arr) {
  let evenCount = 0;
  let oddCount = 0;
  let zeroCount = 0;

  for (const element of arr) {
    // Проверяем, что элемент — число
    if (typeof element !== 'number' || isNaN(element)) {
      continue; // пропускаем нечисловые элементы и NaN
    }

    // Обрабатываем нулевой элемент
    if (element === 0) {
      zeroCount++;
      continue;
    }

    // Определяем чётность для остальных чисел
    if (element % 2 === 0) {
      evenCount++;
    } else {
      oddCount++;
    }
  }

  // Выводим результат в консоль
  console.log(`Чётные: ${evenCount}`);
  console.log(`Нечётные: ${oddCount}`);
  if (zeroCount > 0) {
    console.log(`Нулевые: ${zeroCount}`);
  }
}

Задание 2 
function checkPrimeNumber(num) {
  // Проверка на допустимый диапазон
  if (typeof num !== 'number' || num > 1000 || num < 0 || !Number.isInteger(num)) {
    console.log('Данные неверны');
    return;
  }

  // Особые случаи: 0 и 1 не являются простыми числами
  if (num === 0 || num === 1) {
    console.log(`${num} — не простое число`);
    return;
  }

  // 2 — простое число
  if (num === 2) {
    console.log(`${num} — простое число`);
    return;
  }

  // Чётные числа больше 2 не являются простыми
  if (num % 2 === 0) {
    console.log(`${num} — не простое число`);
    return;
  }

  // Проверяем делители от 3 до квадратного корня из числа, только нечётные
  const sqrt = Math.sqrt(num);
  for (let i = 3; i <= sqrt; i += 2) {
    if (num % i === 0) {
      console.log(`${num} — не простое число`);
      return;
    }
  }

  // Если ни один делитель не найден, число простое
  console.log(`${num} — простое число`);
}


Задание 3 

function createAdder(firstNumber) {
  return function(secondNumber) {
    return firstNumber + secondNumber;
  };
}

// Примеры использования и вывод результатов в консоль
const addFive = createAdder(5);
console.log(addFive(3)); // 8

const addTen = createAdder(10);
console.log(addTen(7)); // 17

console.log(createAdder(2)(8)); // 10
console.log(createAdder(-3)(5)); // 2

Задание 4

function printNumbersInInterval(start, end) {
  // Проверяем корректность входных данных
  if (typeof start !== 'number' || typeof end !== 'number') {
    console.log('Ошибка: аргументы должны быть числами');
    return;
  }

  if (start > end) {
    console.log('Ошибка: первое число должно быть меньше или равно второму');
    return;
  }

  let current = start;
  const intervalId = setInterval(() => {
    console.log(current);

    // Увеличиваем счётчик
    current++;

    // Останавливаем интервал, когда достигли конца диапазона
    if (current > end) {
      clearInterval(intervalId);
    }
  }, 1000); // 1000 мс = 1 секунда
}

// Пример вызова функции
printNumbersInInterval(1, 5);

Задание 5

const power = (x, n) => {
  // Проверка на натуральные числа
  if (!Number.isInteger(x) || !Number.isInteger(n) || x <= 0 || n < 0) {
    throw new Error('Оба аргумента должны быть натуральными числами (x > 0, n ≥ 0)');
  }

  // Частный случай: любое число в степени 0 равно 1
  if (n === 0) return 1;

  let result = 1;
  for (let i = 0; i < n; i++) {
    result *= x;
  }
  return result;
};
